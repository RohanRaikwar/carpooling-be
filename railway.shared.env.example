# Shared Railway variables for all 3 app services:
# - carpooling-api
# - carpooling-mail-worker
# - carpooling-sms-worker

NODE_ENV=production

# Managed Railway services
DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}

# Auth
ACCESS_TOKEN_SECRET=replace-with-a-long-random-secret
REFRESH_TOKEN_SECRET=replace-with-a-different-long-random-secret

# Optional legacy compatibility. Set equal to ACCESS_TOKEN_SECRET if you still need it.
JWT_SECRET=replace-with-the-same-access-token-secret

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=replace-with-mail-username
MAIL_PASS=replace-with-mail-password
MAIL_FROM=Carpooling App <noreply@example.com>

# Maps
GOOGLE_MAPS_API_KEY=replace-with-google-maps-api-key

# Twilio
TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_PHONE_NUMBER=replace-with-twilio-phone-number

# AWS S3
AWS_ACCESS_KEY_ID=replace-with-aws-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-aws-secret-access-key
AWS_REGION=eu-north-1
AWS_S3_BUCKET_NAME=replace-with-s3-bucket-name

# Firebase for Railway. Prefer JSON or base64, not a local file path.
FIREBASE_SERVICE_ACCOUNT_JSON=replace-with-minified-service-account-json
# FIREBASE_SERVICE_ACCOUNT_BASE64=replace-with-base64-encoded-service-account-json
